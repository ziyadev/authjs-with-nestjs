{
  "12776447454124878208": {
    "build": {
      "command": "next build",
      "options": {
        "cwd": "apps/web",
        "tty": false
      },
      "dependsOn": [
        "^build"
      ],
      "cache": true,
      "inputs": [
        "default",
        "^production",
        {
          "externalDependencies": [
            "next"
          ]
        }
      ],
      "outputs": [
        "{workspaceRoot}/apps/web/.next",
        "{workspaceRoot}/apps/web/.next/!(cache)"
      ]
    },
    "dev": {
      "command": "next dev",
      "options": {
        "cwd": "apps/web"
      }
    },
    "start": {
      "command": "next start",
      "options": {
        "cwd": "apps/web"
      },
      "dependsOn": [
        "build"
      ]
    },
    "serve-static": {
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "build",
        "staticFilePath": "{projectRoot}/out",
        "port": 3000,
        "spa": false
      }
    }
  },
